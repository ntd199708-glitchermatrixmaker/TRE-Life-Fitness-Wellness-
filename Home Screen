import React, { useState, useEffect, useRef } from 'react';
import {
  StyleSheet,
  Text,
  View,
  TouchableOpacity,
  ScrollView,
  Linking,
  Alert,
  Platform,
} from 'react-native';
import MapView, { Polyline } from 'react-native-maps';
import * as Location from 'expo-location';
import * as Notifications from 'expo-notifications';
import { StatusBar } from 'expo-status-bar';

// Import components
import StatBox from '../components/StatBox';
import ReminderButton from '../components/ReminderButton';

// Import utils
import { formatTime, calculatePace } from '../utils/formatHelpers';
import { sendNotification } from '../utils/notificationHelper';

export default function HomeScreen() {
  // ---- STATE ----
  const [isTracking, setIsTracking] = useState(false);
  const [isPro, setIsPro] = useState(false);
  const [seconds, setSeconds] = useState(0);
  const [distance, setDistance] = useState(0);
  const [steps, setSteps] = useState(0);
  const [location, setLocation] = useState(null);
  const [route, setRoute] = useState([]);
  const [pace, setPace] = useState('0:00');
  const [alertShown, setAlertShown] = useState(false);

  // ---- REFS ----
  const watchRef = useRef(null);
  const intervalRef = useRef(null);
  const lastPositionRef = useRef(null);

  // ---- NOTIFICATIONS SETUP ----
  useEffect(() => {
    (async () => {
      const { status } = await Notifications.requestPermissionsAsync();
      if (status !== 'granted') {
        Alert.alert('Allow notifications for reminders!');
      }
    })();
  }, []);

  // ---- START TRACKING ----
  const startTracking = async () => {
    const { status } = await Location.requestForegroundPermissionsAsync();
    if (status !== 'granted') {
      Alert.alert('Permission to access location was denied');
      return;
    }

    setIsTracking(true);
    setSeconds(0);
    setDistance(0);
    setSteps(0);
    setRoute([]);
    setAlertShown(false);

    watchRef.current = await Location.watchPositionAsync(
      {
        accuracy: Location.Accuracy.High,
        timeInterval: 1000,
        distanceInterval: 1,
      },
      (newLocation) => {
        const { latitude, longitude } = newLocation.coords;
        setLocation({ latitude, longitude });

        if (lastPositionRef.current) {
          const prev = lastPositionRef.current;
          const delta = Math.sqrt(
            Math.pow(latitude - prev.latitude, 2) +
            Math.pow(longitude - prev.longitude, 2)
          ) * 111.32;

          if (delta > 0.01) {
            setDistance((d) => d + delta);
            setSteps((s) => s + Math.floor(delta * 1300));
          }
        }
        lastPositionRef.current = { latitude, longitude };
        setRoute((prev) => [...prev, { latitude, longitude }]);
      }
    );

    intervalRef.current = setInterval(() => {
      setSeconds((s) => {
        const newSec = s + 1;
        if (distance > 0) {
          setPace(calculatePace(newSec, distance));
        }
        return newSec;
      });
    }, 1000);

    // Send hydration reminder after 1 min (demo)
    setTimeout(() => {
      if (!alertShown) {
        sendNotification('💧 Hydrate!', 'Time to drink water on your run.');
        setAlertShown(true);
      }
    }, 60000);
  };

  // ---- STOP TRACKING ----
  const stopTracking = () => {
    setIsTracking(false);
    if (watchRef.current) watchRef.current.remove();
    if (intervalRef.current) clearInterval(intervalRef.current);
  };

  // ---- PRO UPGRADE ----
  const handleProUpgrade = () => {
    Alert.alert(
      'TRE Fit Pro',
      'Pro features: Advanced safety alerts, traffic rerouting, premium workout plans, and more!',
      [
        { text: 'Subscribe ($4.99/mo)', onPress: () => setIsPro(true) },
        { text: 'Not now', style: 'cancel' },
      ]
    );
  };

  // ---- OPEN SHOP ----
  const openShop = () => {
    Linking.openURL('https://www.trendy.lk').catch(() =>
      Alert.alert('Error', 'Cannot open shop')
    );
  };

  return (
    <ScrollView style={styles.container} showsVerticalScrollIndicator={false}>
      {/* Header */}
      <View style={styles.header}>
        <Text style={styles.title}>🏃 TRE Fit Life Wellness</Text>
        {isPro ? (
          <View style={styles.proBadge}>
            <Text style={styles.proText}>⭐ PRO</Text>
          </View>
        ) : (
          <TouchableOpacity onPress={handleProUpgrade} style={styles.upgradeBtn}>
            <Text style={styles.upgradeText}>Upgrade</Text>
          </TouchableOpacity>
        )}
      </View>

      {/* Map */}
      <View style={styles.mapContainer}>
        {location ? (
          <MapView
            style={styles.map}
            initialRegion={{
              latitude: location.latitude,
              longitude: location.longitude,
              latitudeDelta: 0.01,
              longitudeDelta: 0.01,
            }}
            region={{
              latitude: location.latitude,
              longitude: location.longitude,
              latitudeDelta: 0.01,
              longitudeDelta: 0.01,
            }}
            showsUserLocation={true}
            followsUserLocation={true}
          >
            <Polyline coordinates={route} strokeWidth={4} strokeColor="#FF6B35" />
          </MapView>
        ) : (
          <View style={styles.mapPlaceholder}>
            <Text>📍 Press "Start" to track</Text>
          </View>
        )}
      </View>

      {/* Stats */}
      <View style={styles.statsContainer}>
        <View style={styles.statsRow}>
          <StatBox label="Distance" value={`${distance.toFixed(2)} km`} />
          <StatBox label="Steps" value={steps.toString()} />
          <StatBox label="Pace" value={`${pace} /km`} />
        </View>
        <View style={styles.statsRow}>
          <StatBox label="Time" value={formatTime(seconds)} />
          <StatBox label="Status" value={isTracking ? '▶️ Live' : '⏸️ Paused'} />
        </View>
      </View>

      {/* Controls */}
      <View style={styles.controls}>
        {!isTracking ? (
          <TouchableOpacity style={[styles.btn, styles.startBtn]} onPress={startTracking}>
            <Text style={styles.btnText}>▶ Start</Text>
          </TouchableOpacity>
        ) : (
          <TouchableOpacity style={[styles.btn, styles.stopBtn]} onPress={stopTracking}>
            <Text style={styles.btnText}>⏹ Stop</Text>
          </TouchableOpacity>
        )}
        <TouchableOpacity style={[styles.btn, styles.shopBtn]} onPress={openShop}>
          <Text style={styles.btnText}>🛒 Shop</Text>
        </TouchableOpacity>
      </View>

      {/* Reminders */}
      <View style={styles.reminderContainer}>
        <Text style={styles.reminderTitle}>⏰ Quick Reminders</Text>
        <View style={styles.reminderRow}>
          <ReminderButton
            icon="💧"
            label="Hydrate"
            onPress={() => sendNotification('💧 Drink water!', 'Stay hydrated on your run.')}
          />
          <ReminderButton
            icon="🍌"
            label="Fuel"
            onPress={() => sendNotification('🍌 Fuel up!', 'Grab a snack or energy drink.')}
          />
          {isPro && (
            <ReminderButton
              icon="🚧"
              label="Safety"
              isPro={true}
              onPress={() => Alert.alert('🔊 Safety Alert', 'Road block ahead! Rerouting... (Pro)')}
            />
          )}
        </View>
      </View>

      {/* Footer */}
      <Text style={styles.footer}>💪 Free version powered by trendy.lk</Text>
      <View style={styles.footerSpacing} />
    </ScrollView>
  );
}

